# ── Copy this to .env.prod and fill in all values ─────────────────────────────
# Never commit .env.prod to git.

# App
APP_ENV=production

# OpenAI  (rotate your key at platform.openai.com before going live)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# PostgreSQL  (from Lightsail Managed Database → Connection details)
POSTGRES_USER=dbmasteruser
POSTGRES_PASSWORD=your-db-password
DATABASE_URL=postgresql+asyncpg://dbmasteruser:your-db-password@ls-xxxx.xxxx.ap-south-1.rds.amazonaws.com:5432/idp

# Lightsail Object Storage  (from Lightsail bucket → Access keys)
S3_ENDPOINT_URL=                        # leave blank — Lightsail uses native AWS S3
S3_ACCESS_KEY=your-lightsail-access-key
S3_SECRET_KEY=your-lightsail-secret-key
S3_REGION=ap-south-1
S3_BUCKET_NAME=idp-uploads

# Kafka  (running on Lightsail nano instance)
KAFKA_BOOTSTRAP_SERVERS=<lightsail-instance-private-ip>:9092
KAFKA_EXTRACTION_TOPIC=document-extraction
KAFKA_CONSUMER_GROUP=idp-extraction-group

# Qdrant  (running on same Lightsail nano instance)
QDRANT_HOST=<lightsail-instance-private-ip>
QDRANT_PORT=6333

# Spring Boot ERP  (Lightsail Container Service public endpoint)
ERP_BASE_URL=https://your-erp.lightsailcontainer.com
